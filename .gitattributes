# Normalize line endings: LF in repo, native on checkout for text files
* text=auto eol=lf

# Shell scripts must always be LF (or MSYS2 bash refuses them)
*.sh        text eol=lf
*.bash      text eol=lf
Makefile    text eol=lf
CMakeLists.txt text eol=lf

# Windows-only
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Source code: explicit LF
*.c         text eol=lf
*.h         text eol=lf
*.cpp       text eol=lf
*.hpp       text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.ico       binary
*.hex       binary
*.elf       binary
*.bin       binary
